# This Makevars is the *first* makefile R passes to make, so the first target
# defined here becomes the default goal.  Declare `all` first (its $(SHLIB)
# prerequisite is merged from R's shlib.mk) so that the clean target below
# cannot hijack the default build.
all: $(SHLIB)

.PHONY: all clean
clean:
	rm -f $(OBJECTS) $(SHLIB)
