# Build the bundled OpenFHE library (src/vendor/, produced by tools/vendor.R)
# together with the cpp11 binding glue, using R's own toolchain.  No CMake.
#
# Notes:
# * OpenMP: $(SHLIB_OPENMP_CXXFLAGS) is the only OpenMP wiring.  Where R has
#   no OpenMP (e.g. CRAN macOS) it is empty, _OPENMP is undefined, and the
#   vendored config_core.h leaves OpenFHE's PARALLEL guards off - a serial
#   build, which upstream supports.
# * -DOPENFHE_VERSION is required: upstream stringifies this macro for
#   GetOPENFHEVersion(); without it there is no version fallback.
# * Do not add -O3 / -Werror / -march=native here (CRAN policy).

CXX_STD = CXX17

PKG_CPPFLAGS = -I. -Ivendor -Ivendor/core/include -Ivendor/pke/include \
	-Ivendor/binfhe/include -Ivendor/cereal/include -DOPENFHE_VERSION=1.5.1
PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS)
PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) -pthread

